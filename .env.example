APP_NAME="NETSIGHT Central"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8090

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database configuration (Pointing to host Postgres)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=netsight_central
DB_USERNAME=postgres
DB_PASSWORD=

# Session, Cache & Queue (Ultra-Lean Settings)
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Admin credentials for dashboard access
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
